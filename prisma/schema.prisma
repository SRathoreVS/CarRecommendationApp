datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Car {
  id              String   @id @default(cuid())
  make            String
  model           String
  year            Int

  priceMin        Int      // ex-showroom lowest trim, INR in lakhs * 100 (so 8.5L = 850000)
  priceMax        Int      // top trim

  // Valid values: "HATCHBACK" | "SEDAN" | "SUV" | "MUV"
  bodyType        String

  // Valid values: "PETROL" | "DIESEL" | "CNG" | "ELECTRIC" | "HYBRID"
  fuelType        String

  seatingCapacity Int
  mileage         Float    // kmpl for ICE/CNG/HYBRID, km/charge for ELECTRIC
  safetyRating    Float    // 0-5 GNCAP or estimated

  // Comma-separated, valid values drawn from:
  // "CITY_COMMUTE" | "HIGHWAY_TOURING" | "FAMILY" | "OFFROAD" | "FIRST_CAR"
  // e.g. "CITY_COMMUTE,FAMILY"
  suitedFor       String

  // JSON array of { name: string, category: "safety" | "comfort" | "tech" }
  featuresJson    String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([priceMin, priceMax])
  @@index([bodyType])
  @@index([fuelType])
}
